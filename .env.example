# ──────────────────────────────────────
# CCTaskScoring 环境变量示例
# 复制此文件为 .env 并填入实际值
# ──────────────────────────────────────

# ── ASP.NET Core ──
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# ── SQLite ──
ConnectionStrings__Default=Data Source=data/scoring.db

# ── Neo4j ──
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_neo4j_password

# ── MCP (Anthropic Claude API) ──
MCP_ENDPOINT=https://api.anthropic.com
MCP_API_KEY=sk-ant-your-api-key-here
MCP_TIMEOUT_SECONDS=30
MCP_MAX_RETRIES=3

# ── Neo4j 容器配置 ──
NEO4J_AUTH=neo4j/changeme_neo4j_password
NEO4J_PLUGINS=["apoc"]
